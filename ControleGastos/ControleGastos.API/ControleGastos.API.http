  "descricao": "Salário do mês",
  "valor": 3000.00,
  "tipo": 2,
  "categoriaId": "7de85c01-61f4-46a2-ae4c-64793dcdf97c",
  "pessoaId": "c1818cde-a785-4c48-8c99-a96db23d5cc9"
}

